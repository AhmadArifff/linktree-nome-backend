# ============================================================
# ShopLink Backend — Environment Variables
# Copy file ini menjadi .env dan isi dengan nilai asli
# JANGAN commit file .env ke Git!
# ============================================================

# Supabase — ambil dari Dashboard → Settings → API
SUPABASE_URL=https://dmuruzmlyqdpgztrggsy.supabase.co
SUPABASE_SERVICE_KEY=your_service_key_here
# JWT Secret — buat random string minimal 32 karakter
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=6d47d33e86779b5bab445dfd592a1203cc15cf09565bcabe1310b5c58ad2a9f3

# Server port (lokal)
PORT=3001

# URL Frontend untuk CORS whitelist
FRONTEND_URL=http://localhost:3000

# Node environment
NODE_ENV=development
